# visualastro 2026

font.family:         serif
font.serif:          Palatino, Palatino Linotype, Book Antiqua, P052, serif

text.usetex:         False

mathtext.fontset:    stix

axes.unicode_minus:  True

svg.fonttype: none
pdf.fonttype: 42
ps.fonttype:  42
