# Computer Modern Sans font
# -------------------------
# No Latex
#
# visualastro 2026

font.family:         sans-serif
font.sans-serif:     CMU Sans Serif

text.usetex:         False

mathtext.fontset:    stix
mathtext.fallback:   stix

axes.formatter.use_mathtext: False
axes.unicode_minus:  False

svg.fonttype: path
pdf.fonttype: 42
ps.fonttype:  42
