# Sans-Serif font
# ---------------
# Generic sans-serif fontstyle
# Will vary across systems
#
# No Latex
#
# visualastro 2026

font.family:         sans-serif
font.sans-serif:     DejaVu Sans, Liberation Sans, Arial, Helvetica, sans-serif

text.usetex:         False

mathtext.fontset:    dejavusans

axes.unicode_minus:  True

svg.fonttype: none
pdf.fonttype: 42
ps.fonttype:  42
