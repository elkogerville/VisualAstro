# Computer Modern Typewriter font
# -------------------------------
# No Latex
#
# visualastro 2026

font.family:         monospace
font.monospace:      CMU Typewriter Text

text.usetex:         False
mathtext.fontset:    cm

axes.formatter.use_mathtext: False
axes.unicode_minus:  False

svg.fonttype: path
pdf.fonttype: 42
ps.fonttype:  42
